#!/usr/bin/env bash
# Run opencode against the local Qwen3.6-35B-A3B llama-server (laptop setup).
#
# Routes through the system-message-merging proxy (merge-sys-proxy.py)
# because the Qwen3 chat template rejects any system message that is not
# the first one, while opencode/most agents emit several.
set -e

OC_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/qwen36-mtp/opencode-35b-a3b"
CONFIG_FILE="$OC_DIR/opencode.json"

UPSTREAM="${LLAMA_CPP_BASE_URL:-http://127.0.0.1:8080}"
PROXY_PORT="${OPENCODE_PROXY_PORT:-8094}"
PROXY_BIN="$(dirname "$(dirname "$(readlink -f "$0")")")/scripts/merge-sys-proxy.py"
BASE_URL="http://127.0.0.1:$PROXY_PORT/v1"

# Resolve the context window the running llama-server actually allocated by
# querying its /props endpoint (default_generation_settings.n_ctx). Falls
# back to $CTX_SIZE from the laptop env file (if present), then to 262144.
# opencode's @ai-sdk/openai-compatible plugin does not auto-discover this
# from /v1/models, so we inject it via the schema's `limit` field.
CTX_SIZE_DEFAULT=262144
ENV_FILE="$HOME/.config/qwen36-mtp/laptop.env"
[ -f "$ENV_FILE" ] && . "$ENV_FILE"
CTX_SIZE="${CTX_SIZE:-$CTX_SIZE_DEFAULT}"
DETECTED_CTX="$(curl -s -m 2 "$UPSTREAM/props" 2>/dev/null \
  | python3 -c 'import sys,json; print(json.load(sys.stdin)["default_generation_settings"]["n_ctx"])' 2>/dev/null || true)"
if [ -n "$DETECTED_CTX" ] && [ "$DETECTED_CTX" -gt 0 ] 2>/dev/null; then
  CTX_SIZE="$DETECTED_CTX"
fi
OUTPUT_LIMIT="${OPENCODE_OUTPUT_LIMIT:-16384}"

mkdir -p "$OC_DIR"
cat > "$CONFIG_FILE" <<EOF
{
  "\$schema": "https://opencode.ai/config.json",
  "model": "qwen36-local/qwen3.6-35b-a3b",
  "provider": {
    "qwen36-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Qwen3.6-35B-A3B (local llama.cpp, laptop)",
      "options": {
        "baseURL": "$BASE_URL",
        "apiKey": "sk-local"
      },
      "models": {
        "qwen3.6-35b-a3b": {
          "name": "Qwen3.6-35B-A3B",
          "limit": {
            "context": $CTX_SIZE,
            "output": $OUTPUT_LIMIT
          }
        }
      }
    }
  }
}
EOF

# Start the merging proxy if it isn't already listening on the desired port.
if ! ss -tln 2>/dev/null | grep -q ":$PROXY_PORT "; then
  python3 "$PROXY_BIN" "$PROXY_PORT" "$UPSTREAM" >/dev/null 2>&1 &
  PROXY_PID=$!
  trap 'kill $PROXY_PID 2>/dev/null || true' EXIT INT TERM
  for _ in 1 2 3 4 5; do
    if curl -s -o /dev/null -m 1 "$BASE_URL/models"; then break; fi
    sleep 0.2
  done
fi

export OPENCODE_CONFIG_DIR="$OC_DIR"
opencode --model "qwen36-local/qwen3.6-35b-a3b" "$@"
