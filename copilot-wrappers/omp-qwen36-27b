#!/usr/bin/env bash
# Run oh-my-pi (omp) against the local Qwen3.6-27B llama-server on :8080.
#
# omp emits multiple `system` messages (a default coding prompt followed
# by an environment block), but the Qwen3 chat template embedded in the
# GGUF refuses any system message that isn't the first one. We launch a
# tiny local proxy (merge-sys-proxy.py) that merges all system messages
# before forwarding to llama-server, and point omp at the proxy.
#
# omp's built-in `llama.cpp` provider discovers the model list via
# `${baseUrl}/models` and the context window via `${baseUrl}/../props`,
# both of which our proxy forwards verbatim. The /v1 suffix on baseUrl
# is required so omp hits llama-server's /v1/models endpoint.
set -e

UPSTREAM="${LLAMA_CPP_BASE_URL:-http://127.0.0.1:8080}"
PROXY_PORT="${OMP_PROXY_PORT:-8091}"
PROXY_BIN="$(dirname "$(dirname "$(readlink -f "$0")")")/scripts/merge-sys-proxy.py"

# Resolve the context window the running llama-server actually allocated by
# querying its /props endpoint (default_generation_settings.n_ctx). Falls
# back to $CTX_SIZE from the laptop env file (if present), then to 262144.
# This way models.yml never claims a larger context than the server can
# actually serve, regardless of host or how llama-server was launched.
CTX_SIZE_DEFAULT=262144
ENV_FILE="$HOME/.config/qwen36-mtp/laptop.env"
[ -f "$ENV_FILE" ] && . "$ENV_FILE"
CTX_SIZE="${CTX_SIZE:-$CTX_SIZE_DEFAULT}"
DETECTED_CTX="$(curl -s -m 2 "$UPSTREAM/props" 2>/dev/null \
  | python3 -c 'import sys,json; print(json.load(sys.stdin)["default_generation_settings"]["n_ctx"])' 2>/dev/null || true)"
if [ -n "$DETECTED_CTX" ] && [ "$DETECTED_CTX" -gt 0 ] 2>/dev/null; then
  CTX_SIZE="$DETECTED_CTX"
fi

CONFIG_DIR="$HOME/.omp/agent"
CONFIG_FILE="$CONFIG_DIR/models.yml"

mkdir -p "$CONFIG_DIR"
# We register the model explicitly under the `llama.cpp` provider so that
# omp's synchronous CLI model resolver (resolveCliModel, which runs before
# the async discovery refresh in print mode) can find it. The `discovery:`
# block is kept so the background refresh can still update metadata
# (e.g. context window) from llama-server's /props endpoint.
cat > "$CONFIG_FILE" <<EOF
providers:
  llama.cpp:
    baseUrl: http://127.0.0.1:$PROXY_PORT/v1
    api: openai-completions
    auth: none
    discovery:
      type: llama.cpp
    models:
      - id: qwen3.6-27b
        name: Qwen3.6-27B
        api: openai-completions
        contextWindow: $CTX_SIZE
        maxTokens: $CTX_SIZE
EOF

# Start the merging proxy if it isn't already listening on the desired port.
if ! ss -tln 2>/dev/null | grep -q ":$PROXY_PORT "; then
  python3 "$PROXY_BIN" "$PROXY_PORT" "$UPSTREAM" >/dev/null 2>&1 &
  PROXY_PID=$!
  trap 'kill $PROXY_PID 2>/dev/null || true' EXIT INT TERM
  for _ in 1 2 3 4 5 10; do
    if curl -s -o /dev/null -m 1 "http://127.0.0.1:$PROXY_PORT/v1/models"; then break; fi
    sleep 0.2
  done
fi

# Fake it so that the local model is "authenticated" to be used as subagent. See https://github.com/can1357/oh-my-pi/issues/1008
export LLAMA_CPP_API_KEY=dummy

omp --model 'llama.cpp/qwen3.6-27b' "$@"
